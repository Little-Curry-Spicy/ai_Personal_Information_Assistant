MODEL_NAME=qwen-plus
OPENAI_API_KEY=sk-xx-xxx 
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BOCHA_API_KEY = sk-xx-xxx

PORT=3001

# 按 IP 限流：每个时间窗口内最多请求次数（默认 20）
RATE_LIMIT_MAX=20
# 时间窗口（毫秒），默认 60000（1 分钟）
RATE_LIMIT_WINDOW_MS=60000
# 设为 false 或 0 可关闭限流
RATE_LIMIT_ENABLED=true
# 在 Nginx 等反代后部署时设为 true，以便 req.ip 使用可信的 X-Forwarded-For
TRUST_PROXY=false

# 须与 Qdrant 集合「向量维度」一致（常见512 / 1024；控制台与 EMBEDDING_DIMENSIONS 不匹配会 upsert 400）
EMBEDDING_DIMENSIONS=512
QDRANT_COLLECTION_FILE=resume
QDRANT_COLLECTION_GITHUB=github
EMBEDDING_MODEL=text-embedding-v4
QDRANT_URL=https://xx-xxx.sa-east-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=xx-xxx